local active           = false
local startedAt        = 0
local boundKey         = Enum.KeyCode.V
local waitingForKey    = false
local selectedPlatform = "PC"
local defaultPowers = { PC = 97000, MOBILE = 72000 }
local function formatPower(num)
	if num >= 1000 then
		return string.format("%dK", math.floor(num / 1000 + 0.5))
	end
	return tostring(num)
end
local function getCurrentPower()
	local n = tonumber(powerBox.Text)
	if not n then n = defaultPowers[selectedPlatform] end
	return math.clamp(math.floor(n + 0.5), 1, 999999)
end
local function syncButtons()
	local label = active and "DEACTIVATE" or "ACTIVATE"
	activateButton.Text        = label
	hiddenActivateButton.Text  = label
end
local function setActive(state)
	active = state
	if state then
		startedAt = os.clock()
		statusLabel.Text      = "ONLINE"
		statusLabel.TextColor3 = Color3.fromRGB(227, 45, 45)
		activateButton.BackgroundColor3       = Color3.fromRGB(228, 34, 34)
		activateButton.TextColor3             = Color3.fromRGB(255, 255, 255)
		hiddenActivateButton.BackgroundColor3 = Color3.fromRGB(228, 34, 34)
		hiddenActivateButton.TextColor3       = Color3.fromRGB(255, 255, 255)
		startBypass(getCurrentPower())
	else
		statusLabel.Text       = "OFFLINE"
		statusLabel.TextColor3 = Color3.fromRGB(126, 126, 126)
		activateButton.BackgroundColor3       = Color3.fromRGB(16, 16, 16)
		activateButton.TextColor3             = Color3.fromRGB(226, 52, 52)
		hiddenActivateButton.BackgroundColor3 = Color3.fromRGB(16, 16, 16)
		hiddenActivateButton.TextColor3       = Color3.fromRGB(226, 52, 52)
		timerText.Text = "00:00"
		stopBypass()
	end
	syncButtons()
end
local function setPlatform(platform)
	selectedPlatform = platform
	local isMobile = platform == "MOBILE"
	TweenService:Create(selectorFill, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Position = isMobile and UDim2.new(0.5, 1, 0, 2) or UDim2.fromOffset(2, 2)
	}):Play()
	local p = defaultPowers[platform]
	powerBox.Text  = tostring(p)
	powerText.Text = formatPower(p)
	if active then startBypass(p) end
end
