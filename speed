local dragging, dragStart, startPos, dragTarget = false, nil, nil, nil
local function beginDrag(input, target)
	if input.UserInputType == Enum.UserInputType.MouseButton1
	or input.UserInputType == Enum.UserInputType.Touch then
		dragging   = true
		dragStart  = input.Position
		dragTarget = target
		startPos   = target.Position
	end
end
main.InputBegan:Connect(function(input)        beginDrag(input, main) end)
hiddenFrame.InputBegan:Connect(function(input) beginDrag(input, hiddenFrame) end)
UserInputService.InputChanged:Connect(function(input)
	if dragging and dragTarget and (input.UserInputType == Enum.UserInputType.MouseMovement
	or input.UserInputType == Enum.UserInputType.Touch) then
		local delta  = input.Position - dragStart
		local newPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		dragTarget.Position = newPos
		if dragTarget == main then
			hiddenFrame.Position = newPos
		else
			main.Position = newPos
		end
	end
end)
UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
	or input.UserInputType == Enum.UserInputType.Touch then
		dragging   = false
		dragTarget = nil
	end
end)
RunService.RenderStepped:Connect(function(dt)
	ringGradient.Rotation = (ringGradient.Rotation + dt * 95) % 360
	if active then
		local elapsed  = math.floor(os.clock() - startedAt)
		timerText.Text = string.format("%02d:%02d", math.floor(elapsed / 60), elapsed % 60)
	end
end)
