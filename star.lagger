local sliderDragging = false
local function updateIntensity(px)
    local trackAbs = track.AbsolutePosition.X
    local trackW = track.AbsoluteSize.X
    local relX = math.clamp(px - trackAbs, 0, trackW)
    local pct = relX / trackW
    local val = math.floor(100 + (pct * 900))
    State.intensity = val
    fill.Size = UDim2.new(pct, 0, 1, 0)
    handle.Position = UDim2.new(pct, -8, 0.5, -8)
    intensityValue.Text = tostring(val)
    -- Update current mode base
    if Modes[State.mode] then
        Modes[State.mode].base = val
    end
    saveConfig()
end
track.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
        sliderDragging = true
        updateIntensity(inp.Position.X)
    end
end)
UIS.InputChanged:Connect(function(inp)
    if sliderDragging and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
        updateIntensity(inp.Position.X)
    end
end)
UIS.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
        sliderDragging = false
    end
end)
local keybindFrame = Instance.new("Frame", content)
keybindFrame.Size = UDim2.new(1, 0, 0, 42)
keybindFrame.BackgroundColor3 = C.card
keybindFrame.BorderSizePixel = 0
keybindFrame.LayoutOrder = 6
keybindFrame.ZIndex = 2
local keybindCorner = Instance.new("UICorner", keybindFrame)
keybindCorner.CornerRadius = UDim.new(0, 10)
local keybindStroke = Instance.new("UIStroke", keybindFrame)
keybindStroke.Color = C.border
keybindStroke.Thickness = 1
local keybindLabel = Instance.new("TextLabel", keybindFrame)
keybindLabel.Size = UDim2.new(0, 100, 1, 0)
keybindLabel.Position = UDim2.new(0, 12, 0, 0)
keybindLabel.BackgroundTransparency = 1
keybindLabel.Text = "TOGGLE KEY"
keybindLabel.TextColor3 = C.textDim
keybindLabel.Font = Enum.Font.GothamBold
keybindLabel.TextSize = 11
keybindLabel.TextXAlignment = Enum.TextXAlignment.Left
keybindLabel.ZIndex = 3
local keybindBtn = Instance.new("TextButton", keybindFrame)
keybindBtn.Size = UDim2.new(0, 70, 0, 30)
keybindBtn.Position = UDim2.new(1, -82, 0.5, -15)
keybindBtn.BackgroundColor3 = C.panel
keybindBtn.Text = State.keybind.Name
keybindBtn.TextColor3 = C.accent
keybindBtn.Font = Enum.Font.GothamBold
keybindBtn.TextSize = 12
keybindBtn.AutoButtonColor = false
keybindBtn.BorderSizePixel = 0
keybindBtn.ZIndex = 3
local keybindBtnCorner = Instance.new("UICorner", keybindBtn)
keybindBtnCorner.CornerRadius = UDim.new(0, 6)
local keybindBtnStroke = Instance.new("UIStroke", keybindBtn)
keybindBtnStroke.Color = C.borderLight
keybindBtnStroke.Thickness = 1.5
local listening = false
local listenConn = nil
local function stopListening(key)
    listening = false
    if listenConn then listenConn:Disconnect(); listenConn = nil end
    keybindBtn.TextColor3 = C.accent
    if key then
        State.keybind = key
        keybindBtn.Text = key.Name
        saveConfig()
    end
end
keybindBtn.MouseButton1Click:Connect(function()
    if listening then stopListening(nil); return end
    listening = true
    keybindBtn.Text = "..."
    keybindBtn.TextColor3 = C.accent2
    listenConn = UIS.InputBegan:Connect(function(inp)
        if not listening then return end
        if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end
        if inp.KeyCode == Enum.KeyCode.Escape then stopListening(nil); return end
        stopListening(inp.KeyCode)
    end)
end)
local dragging, dragStart, startPos = false, nil, nil
header.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = inp.Position
        startPos = mainFrame.Position
        inp.Changed:Connect(function()
            if inp.UserInputState == Enum.UserInputState.End then
                dragging = false
                saveConfig()
            end
        end)
    end
end)
UIS.InputChanged:Connect(function(inp)
    if dragging and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
        local delta = inp.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputBegan:Connect(function(inp, processed)
    if processed then return end
    if listening then
        if inp.KeyCode == Enum.KeyCode.Escape then
            stopListening(nil)
        elseif inp.UserInputType == Enum.UserInputType.Keyboard then
            stopListening(inp.KeyCode)
        end
        return
    end
    if inp.KeyCode == State.keybind and inp.UserInputType == Enum.UserInputType.Keyboard then
        doToggle()
    elseif inp.KeyCode == Enum.KeyCode.LeftControl then
        mainFrame.Visible = not mainFrame.Visible
        State.guiVisible = mainFrame.Visible
    end
end)
mainFrame.Size = UDim2.new(0, 360, 0, 0)
mainFrame.Visible = true
TweenService:Create(mainFrame, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
    Size = UDim2.new(0, 360, 0, 420)
}):Play()
task.spawn(function()
    while task.wait(2) do
        if not glow or not glow.Parent then break end
        TweenService:Create(glow, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            BackgroundTransparency = 0.92
        }):Play()
        task.wait(1)
        if not glow or not glow.Parent then break end
        TweenService:Create(glow, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            BackgroundTransparency = 0.95
        }):Play()
    end
end)
print("[STAR Lagger V2] Loaded with advanced engine!")
print("Modes: Normal | Pulse | Burst | Stealth | Demon")
print("Keybind: " .. State.keybind.Name)
