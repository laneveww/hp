local function updateStatus()
    local isOn = Lagger.isRunning
    statusLabel.Text = isOn and "ENABLED" or "DISABLED"
    statusLabel.TextColor3 = isOn and C.statusOn or C.statusOff
    statusIndicator.BackgroundColor3 = isOn and C.statusOn or C.statusOff
    toggleBtn.Text = isOn and "STOP" or "START"
    toggleBtn.BackgroundColor3 = isOn and C.accent2 or C.accent
    TweenService:Create(statusCard, TweenInfo.new(0.3), {
        BackgroundColor3 = isOn and Color3.fromRGB(25, 35, 30) or C.card
    }):Play()
    TweenService:Create(statusStroke, TweenInfo.new(0.3), {
        Color = isOn and C.statusOn or C.border
    }):Play()
end
local function doToggle()
    toggleLagger()
    updateStatus()
end
toggleBtn.MouseButton1Click:Connect(doToggle)
statusCard.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
        doToggle()
    end
end)
