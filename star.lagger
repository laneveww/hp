    end
end)
task.spawn(function()
    while task.wait(0.5) do
        if not statsLabel or not statsLabel.Parent then break end
        if Lagger.isRunning then
            local elapsed = tick() - State.stats.startTime
            local rate = elapsed > 0 and math.floor(State.stats.packets / elapsed * 10) / 10 or 0
            statsLabel.Text = string.format("%d packets â€¢ %.1f/s", State.stats.packets, rate)
        else
            statsLabel.Text = "0 packets"
        end
    end
end)
