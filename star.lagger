local modeButtons = {}
local function updateModeVisuals()
    for name, btn in pairs(modeButtons) do
        local isActive = (State.mode == name)
        local modeColor = Modes[name].demon and C.modeDemon or 
                         (Modes[name].burst and C.modeBurst or 
                         (Modes[name].pulse and C.modePulse or 
                         (Modes[name].stealth and C.modeStealth or C.modeNormal)))
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = isActive and modeColor or C.card,
            BackgroundTransparency = isActive and 0.2 or 0
        }):Play()
        btn.TextColor3 = isActive and C.text or C.textDim
        btn.Text = isActive and ("â€¢ " .. name:upper()) or name:upper()
    end
end
for modeName, modeData in pairs(Modes) do
    local btn = Instance.new("TextButton", modeFrame)
    btn.Size = UDim2.new(0.32, -6, 0, 36)
    btn.BackgroundColor3 = C.card
    btn.Text = modeName:upper()
    btn.TextColor3 = C.textDim
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 10
    btn.AutoButtonColor = false
    btn.BorderSizePixel = 0
    btn.ZIndex = 3
    local btnCorner = Instance.new("UICorner", btn)
    btnCorner.CornerRadius = UDim.new(0, 8)
    local btnStroke = Instance.new("UIStroke", btn)
    btnStroke.Color = C.border
    btnStroke.Thickness = 1
    btn.MouseEnter:Connect(function()
        if State.mode ~= modeName then
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = C.cardHover}):Play()
        end
    end)
    btn.MouseLeave:Connect(function()
        if State.mode ~= modeName then
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = C.card}):Play()
        end
    end)
    btn.MouseButton1Click:Connect(function()
        State.mode = modeName
        State.intensity = modeData.base
        updateModeVisuals()
        saveConfig()
        -- Restart if running
        if Lagger.isRunning then
            stopLagger()
            task.wait(0.1)
            startLagger()
        end
    end)
    modeButtons[modeName] = btn
end
updateModeVisuals()
