-- Update UI
local function updateUI()
    if config.isEnabled then
        TextButton3.Text = "ENABLED"
        TextButton3.TextColor3 = Color3.fromRGB(220, 45, 45)
        TextButton3.BackgroundColor3 = Color3.fromRGB(30, 10, 12)
        TextButton5.Text = "ON"
        TextButton5.TextColor3 = Color3.fromRGB(220, 45, 45)
        TextButton5.BackgroundColor3 = Color3.fromRGB(30, 10, 12)
    else
        TextButton3.Text = "DISABLED"
        TextButton3.TextColor3 = Color3.fromRGB(150, 150, 180)
        TextButton3.BackgroundColor3 = Color3.fromRGB(22, 9, 11)
        TextButton5.Text = "OFF"
        TextButton5.TextColor3 = Color3.fromRGB(150, 150, 180)
        TextButton5.BackgroundColor3 = Color3.fromRGB(22, 9, 11)
    end
    
    if config.isMobileMode then
        Frame5.Position = UDim2.new(0.5, 2, 0, 2)
        TextButton2.TextColor3 = Color3.fromRGB(245, 245, 245)
        TextButton.TextColor3 = Color3.fromRGB(120, 120, 120)
        Frame11.Visible = true
        Frame7.Visible = false
    else
        Frame5.Position = UDim2.new(0, 2, 0, 2)
        TextButton.TextColor3 = Color3.fromRGB(245, 245, 245)
        TextButton2.TextColor3 = Color3.fromRGB(120, 120, 120)
        Frame11.Visible = false
        Frame7.Visible = true
    end
    
    TextButton4.Text = config.keybind
    TextBox.Text = tostring(config.pcPower)
    TextBox2.Text = tostring(config.mobilePower)
    
    UIScale.Scale = config.guiScale
    local relativeX = (config.guiScale - 0.5) / 2
    Frame16.Size = UDim2.new(relativeX, 0, 1, 0)
    Frame17.Position = UDim2.new(relativeX, 0, 0.5, 0)
    TextLabel6.Text = math.floor(config.guiScale * 100) .. "%"
end

-- Toggle
local function toggleEnabled()
    config.isEnabled = not config.isEnabled
    updateUI()
    saveConfig()
    if config.isEnabled then
        startBypass()
