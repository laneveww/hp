-- Save/Load Config
local function saveConfig()
    if writefile then
        pcall(function()
            if not isfolder("VampireBypass") then
                makefolder("VampireBypass")
            end
            writefile("VampireBypass/config.json", HttpService:JSONEncode(config))
        end)
    end
end

local function loadConfig()
    if isfile and isfile("VampireBypass/config.json") then
        local success, data = pcall(function()
            return HttpService:JSONDecode(readfile("VampireBypass/config.json"))
        end)
        if success and data then
            for k, v in pairs(data) do
                if config[k] ~= nil then
                    config[k] = v
                end
            end
        end
    end
end
loadConfig()

