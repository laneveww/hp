-- Number validation
local function validateNumber(textbox, isPC)
    local num = tonumber(textbox.Text)
    if not num or num < 10000 then num = isPC and 97000 or 72000 end
    if num > 150000 then num = 150000 end
    num = math.floor(num)
    textbox.Text = tostring(num)
    if isPC then config.pcPower = num else config.mobilePower = num end
    saveConfig()
    if running then restartSpamLoop() end
end

TextBox.FocusLost:Connect(function() validateNumber(TextBox, true) end)
TextBox2.FocusLost:Connect(function() validateNumber(TextBox2, false) end)

-- Dragging
Frame3.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDragging = true
        dragStart = input.Position
        startPos = Frame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
    if isResizing and input.UserInputType == Enum.UserInputType.MouseMovement then
        local relativeX = (input.Position.X - Frame15.AbsolutePosition.X) / Frame15.AbsoluteSize.X
        relativeX = math.clamp(relativeX, 0, 1)
        config.guiScale = 0.5 + (relativeX * 2)
        updateUI()
        saveConfig()
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        if isDragging then config.guiPosition = Frame.Position; saveConfig() end
        isDragging = false
        isResizing = false
    end
end)

